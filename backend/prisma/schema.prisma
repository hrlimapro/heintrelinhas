datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  WRITER
  EDITOR
  ADMIN
}

enum PostStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(WRITER)
  createdAt    DateTime @default(now())
  posts        Post[]

  @@map("users")
}

model Post {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  summary     String
  content     String
  status      PostStatus @default(DRAFT)
  readingTime Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?

  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  tags        Tag[]

  @@map("posts")
}

model Category {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  posts Post[]

  @@map("categories")
}

model Tag {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  posts Post[]

  @@map("tags")
}
